{
  "name": "@craving-house/web",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.14.1 <25"
  },
  "scripts": {
    "dev": "node scripts/next-bin.mjs dev -H 127.0.0.1 -p 3000",
    "build": "prisma generate && node scripts/next-bin.mjs build",
    "start": "node scripts/start.mjs",
    "lint": "eslint . --max-warnings=0",
    "test": "node --experimental-strip-types --test ./src/server/auth/*.test.ts ./src/server/payments/*.test.ts ./src/lib/*.test.ts",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "node prisma/deploy.cjs",
    "prisma:push": "prisma db push",
    "prisma:seed": "node prisma/seed.cjs",
    "dev:setup": "npm run prisma:generate && npm run prisma:push && npm run prisma:seed"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.11.0",
    "bn.js": "^4.12.3",
    "next": "^16.2.2",
    "next-auth": "^4.24.13",
    "nodemailer": "^8.0.4",
    "prisma": "^5.11.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/web-push": "^3.6.4",
    "brace-expansion": "^1.1.13",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.2",
    "picomatch": "^4.0.4",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.58.0"
  }
}
