DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/craving_house"

NEXTAUTH_URL="https://your-domain.example"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_DEBUG="false"
FORCE_SECURE_SESSION_COOKIE_IN_PRODUCTION="true"
MFA_ENCRYPTION_KEY="replace-with-a-different-long-random-secret"

# OAuth providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe Checkout
STRIPE_SECRET_KEY="replace-with-your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="replace-with-your-stripe-webhook-secret"
STRIPE_WEBHOOK_IP_ALLOWLIST=""

# QR and manager setup
QR_SECRET="replace-with-a-long-random-secret"
INITIAL_MANAGER_SETUP_CODE="replace-with-a-long-random-code"

# Dev auth
DEV_AUTH_ENABLED="false"
NEXT_PUBLIC_DEV_AUTH_ENABLED="false"
DEV_AUTH_CODE=""

# Notifications
VAPID_PRIVATE_KEY=""
VAPID_PUBLIC_KEY=""
VAPID_SUBJECT="https://your-domain.example"

# Email receipts
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Craving House <orders@your-domain.example>"

# Optional
NEXT_PUBLIC_SUPPORT_EMAIL="support@your-domain.example"
HEALTHCHECK_TOKEN=""
